# ============================================================
# backend/.env.example
# Copie para .env e preencha os valores
# ============================================================

# ── Banco de dados ───────────────────────────────────────────
# Formato: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# Para desenvolvimento local com o docker-compose do projeto, suba o serviço
# com `docker compose up -d ts-compilator-db` e use a URL abaixo (porta 5434
# no host para evitar colisão com outros postgres locais).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/tscompilator
DATABASE_SCHEMA=public


# ── Segurança ────────────────────────────────────────────────
SECRET_KEY=                # obrigatório — gere com: openssl rand -hex 32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────
# Lista JSON de origens permitidas
CORS_ORIGINS=["http://localhost:3001"]

# ── Desenvolvimento ──────────────────────────────────────────
# NUNCA use true em produção
RUN_CREATE_ALL=false
