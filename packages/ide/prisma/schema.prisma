generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  classes   Class[]
}

model User {
  id             String          @id @default(uuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  role           UserRole        @default(STUDENT)
  email          String          @unique
  password       String
  name           String
  avatarUrl      String?
  bio            String?
  classesTaught  Class[]         @relation("TeacherToClass")
  memberships    ClassMember[]
  submissions    Submission[]
  exercises      Exercise[]
  exerciseLists  ExerciseList[]
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

model Class {
  id             String              @id @default(uuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  teacherId      String
  teacher        User                @relation("TeacherToClass", fields: [teacherId], references: [id])
  name           String
  description    String
  accessCode     String              @unique
  createdAt      DateTime            @default(now())
  status         ClassStatus         @default(ACTIVE)
  members        ClassMember[]
  exerciseLists  ClassExerciseList[]
}

enum ClassStatus {
  ACTIVE
  ARCHIVED
}

model ClassMember {
  classId   String
  studentId String
  class     Class    @relation(fields: [classId], references: [id])
  student   User     @relation(fields: [studentId], references: [id])
  joinedAt  DateTime @default(now())

  @@id([classId, studentId])
}

model Exercise {
  id          String             @id @default(uuid())
  teacherId   String
  teacher     User               @relation(fields: [teacherId], references: [id])
  title       String
  description String
  attachments String
  status      ExerciseStatus     @default(DRAFT)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  submissions Submission[]
  testCases   TestCase[]
  listItems   ExerciseListItem[]

  @@index([teacherId])
}

enum ExerciseStatus {
  DRAFT
  PUBLISHED
}

model ExerciseList {
  id          String              @id @default(uuid())
  teacherId   String
  teacher     User                @relation(fields: [teacherId], references: [id])
  title       String
  description String
  status      ExerciseListStatus  @default(DRAFT)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  items       ExerciseListItem[]
  classes     ClassExerciseList[]

  @@index([teacherId])
}

enum ExerciseListStatus {
  DRAFT
  PUBLISHED
}

model ExerciseListItem {
  exerciseListId String
  exerciseId     String
  exerciseList   ExerciseList @relation(fields: [exerciseListId], references: [id], onDelete: Cascade)
  exercise       Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  gradeWeight    Float
  orderIndex     Int          @default(0)

  @@id([exerciseListId, exerciseId])
}

model ClassExerciseList {
  exerciseListId String
  classId        String
  exerciseList   ExerciseList  @relation(fields: [exerciseListId], references: [id], onDelete: Cascade)
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  deadline       DateTime
  totalGrade     Float
  minRequired    Int
  publishedAt    DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  submissions    Submission[]

  @@id([exerciseListId, classId])
  @@index([classId])
  @@index([deadline])
}

model Submission {
  id               String            @id @default(uuid())
  exerciseId       String
  exercise         Exercise          @relation(fields: [exerciseId], references: [id])
  exerciseListId   String
  classId          String
  publication      ClassExerciseList @relation(fields: [exerciseListId, classId], references: [exerciseListId, classId])
  studentId        String
  student          User              @relation(fields: [studentId], references: [id])
  codeSnapshot     String
  status           SubmissionStatus  @default(PENDING)
  score            Float?
  teacherFeedback  String?
  submittedAt      DateTime          @default(now())

  @@index([exerciseListId, classId])
  @@index([studentId])
}

model TestCase {
  id             String   @id @default(uuid())
  exerciseId     String
  exercise       Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  label          String   @default("")
  input          String
  expectedOutput String
  orderIndex     Int      @default(0)
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
  LATE
}
