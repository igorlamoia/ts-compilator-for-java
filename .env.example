# ============================================================
# .env.example — Projeto raiz (usado pelo docker-compose.yml)
# Copie para .env e preencha os valores antes de subir os containers
# ============================================================

# ── Banco de dados ───────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=               # obrigatório
DB_HOST=localhost          # use "host.docker.internal" se o DB estiver fora do Docker
DB_PORT=5432
DB_NAME=tscompilator
DATABASE_SCHEMA=public

# ── Backend ──────────────────────────────────────────────────
SECRET_KEY=                # obrigatório — gere com: openssl rand -hex 32
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=["http://localhost:3001"]
RUN_CREATE_ALL=false       # NUNCA use true em produção

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
